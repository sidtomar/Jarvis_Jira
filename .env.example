# ─── OpenRouter Configuration ──────────────────────────────────────────────────
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Default model (can be overridden in the sidebar)
# Popular options: openai/gpt-4o, anthropic/claude-sonnet-4, google/gemini-2.5-flash-preview
OPENROUTER_MODEL=openai/gpt-4o

# ─── Jira Configuration ────────────────────────────────────────────────────────
# Your Atlassian base URL (no trailing slash)
JIRA_BASE_URL=https://yourorg.atlassian.net

# Email address associated with your Jira account
JIRA_EMAIL=you@company.com

# Jira API token (generate at: https://id.atlassian.com/manage-profile/security/api-tokens)
JIRA_API_TOKEN=your-jira-api-token-here

# Default Jira project key (can be overridden in the sidebar)
JIRA_PROJECT_KEY=PROJ

# Default issue type (Story, Task, Bug, etc.)
JIRA_ISSUE_TYPE=Story
